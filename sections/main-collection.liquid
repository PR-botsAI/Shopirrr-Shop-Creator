<div class="container section">
  <div style="text-align:center;margin-bottom:3rem;">
    <h1 class="heading-display gradient-text" style="font-size:clamp(2rem,5vw,3.5rem);margin-bottom:1rem;">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p style="color:rgba(250,250,250,0.5);max-width:500px;margin:0 auto;">{{ collection.description }}</p>
    {% endif %}
  </div>
  <div class="products-grid">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="card product-card">
        <div class="product-card__image">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="800">
          {% endif %}
        </div>
        <div class="product-card__info">
          <h3 class="product-card__title">{{ product.title }}</h3>
          <p class="product-card__price">{{ product.price | money }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{ "name": "Collection" }
{% endschema %}
