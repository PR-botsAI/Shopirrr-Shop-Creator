<section class="section">
  <div class="container">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:3rem;">
      <div>
        <h2 class="heading-display gradient-text" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:0.5rem;">{{ section.settings.title }}</h2>
        <p style="color:rgba(250,250,250,0.5);">{{ section.settings.subtitle }}</p>
      </div>
      <a href="{{ section.settings.view_all_url }}" class="btn btn-outline" style="display:none;" id="view-all-btn">View All →</a>
    </div>
    <div class="products-grid">
      {% for product in collections[section.settings.collection].products limit: section.settings.products_count %}
        <a href="{{ product.url }}" class="card product-card">
          <div class="product-card__image">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="600" height="800">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,rgba(255,45,120,0.2),rgba(123,47,255,0.2));display:flex;align-items:center;justify-content:center;">No image</div>
            {% endif %}
            {% for tag in product.tags %}
              {% if tag == 'new' %}<span class="badge" style="position:absolute;top:0.75rem;left:0.75rem;">NEW</span>{% endif %}
            {% endfor %}
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">{{ product.title }}</h3>
            <p class="product-card__price">{{ product.price | money }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Featured" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Curated picks you'll obsess over" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_count", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "url", "id": "view_all_url", "label": "View all link", "default": "/collections/all" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
