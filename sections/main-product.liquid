<div class="container section">
  <div style="display:grid;grid-template-columns:1fr;gap:3rem;" class="product-layout">
    <div class="product-media">
      {% if product.featured_image %}
        <div style="border-radius:1.5rem;overflow:hidden;aspect-ratio:1;background:var(--color-deep);border:1px solid rgba(255,255,255,0.08);">
          <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" style="width:100%;height:100%;object-fit:cover;" width="800" height="800">
        </div>
      {% endif %}
    </div>
    <div class="product-info">
      <div style="margin-bottom:1rem;">
        {% for tag in product.tags limit: 3 %}
          <span class="badge" style="margin-right:0.5rem;">{{ tag }}</span>
        {% endfor %}
      </div>
      <h1 class="heading-display" style="font-size:clamp(1.75rem,3vw,2.5rem);margin-bottom:1rem;">{{ product.title }}</h1>
      <p style="font-size:1.5rem;font-weight:700;color:var(--color-pink);margin-bottom:1.5rem;">{{ product.price | money }}</p>
      <div style="color:rgba(250,250,250,0.6);line-height:1.8;margin-bottom:2rem;">{{ product.description }}</div>
      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn btn-primary" style="width:100%;padding:1rem 2rem;font-size:1rem;" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Bag{% else %}Sold Out{% endif %}
        </button>
      {% endform %}
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-top:2rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,0.08);">
        {% for badge in '🌿 Vegan,🐰 Cruelty-Free,♻️ Eco Pack' | split: ',' %}
          <div style="text-align:center;padding:0.75rem;border-radius:0.75rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);font-size:0.8rem;color:rgba(250,250,250,0.5);">{{ badge }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Product" }
{% endschema %}
